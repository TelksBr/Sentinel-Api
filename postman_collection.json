            },
            "url": {
              "raw": "{{baseUrl}}/ssh_user/enable/usuario1",
              "host": ["{{baseUrl}}"],
              "path": ["ssh_user", "enable", "usuario1"]
            },
            "description": "Habilita um usuário SSH (define data de expiração)"
          }
        },
        {
          "name": "Deletar Usuários SSH",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{apiKey}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "[\"usuario1\", \"usuario2\", \"teste1\"]"
            },
            "url": {
              "raw": "{{baseUrl}}/ssh_user/delete",
              "host": ["{{baseUrl}}"],
              "path": ["ssh_user", "delete"]
