              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "[\"usuario1\", \"usuario2\", \"teste1\"]"
            },
            "url": {
              "raw": "{{baseUrl}}/ssh_user/delete",
              "host": ["{{baseUrl}}"],
              "path": ["ssh_user", "delete"]
