{
  "info": {
    "name": "Sentinel API",
    "description": "Coleção completa da Sentinel API - Gerenciamento de usuários SSH, V2Ray e DT-Proto",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.2.0"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://suaurl-da-api:port",
      "type": "string"
    },
    {
      "key": "apiKey",
      "value": "sua-chave-api-aqui",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/",
          "host": ["{{baseUrl}}"],
          "path": [""]
        },
        "description": "Verifica se a API está funcionando. Rota pública (sem autenticação)."
      }
    },
    {
      "name": "Usuários Online (Contadores)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/onlines",
          "host": ["{{baseUrl}}"],
          "path": ["onlines"]
        },
        "description": "Retorna contadores de usuários SSH, V2Ray e DT-Proto online (do cache). Rota pública (sem autenticação)."
      },
      "response": [
        {
          "name": "Success",
          "originalRequest": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/onlines",
              "host": ["{{baseUrl}}"],
              "path": ["onlines"]
            }
          },
          "status": "OK",
          "code": 200,
          "_postman_previewlanguage": "json",
          "header": [
            {
              "key": "Content-Type",
              "value": "application/json"
            }
          ],
          "cookie": [],
          "body": "{\n  \"ssh_users\": 5,\n  \"v2ray_users\": 12,\n  \"dt_proto_users\": 8,\n  \"total_users\": 25\n}"
        }
      ]
    },
