            ],
            "url": {
              "raw": "{{baseUrl}}/ssh_user/delete_all",
              "host": ["{{baseUrl}}"],
              "path": ["ssh_user", "delete_all"]
            },
            "description": "Deleta TODOS os usuários SSH do servidor (retorna estatísticas detalhadas)"
          }
        }
      ]
