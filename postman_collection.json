{
  "info": {
    "name": "API Atlas V2",
    "description": "Coleção completa da API Atlas V2 - Gerenciamento de usuários SSH e V2Ray",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.1.0"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://premium1.sshtproject.com:8090",
      "type": "string"
    },
    {
      "key": "apiKey",
      "value": "sua-chave-api-aqui",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{apiKey}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/",
          "host": ["{{baseUrl}}"],
          "path": [""]
        },
        "description": "Verifica se a API está funcionando"
      }
    },
    {
      "name": "Usuários Online (Contadores)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{apiKey}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/onlines",
          "host": ["{{baseUrl}}"],
          "path": ["onlines"]
        },
        "description": "Retorna contadores de usuários SSH e V2Ray online (do cache)"
      }
    },
    {
      "name": "Usuários Online (Lista Detalhada)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{apiKey}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/users/online",
          "host": ["{{baseUrl}}"],
          "path": ["users", "online"]
        },
        "description": "Retorna lista detalhada de usuários SSH e V2Ray online (do cache)"
      },
      "response": [
        {
          "name": "Success",
          "originalRequest": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{apiKey}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/",
              "host": ["{{baseUrl}}"],
              "path": [""]
            }
          },
          "status": "OK",
          "code": 200,
          "_postman_previewlanguage": "json",
          "header": [
            {
              "key": "Content-Type",
              "value": "application/json"
            }
          ],
          "cookie": [],
          "body": "{\n  \"message\": \"🟢 API running !\"\n}"
        }
      ]
    },
    {
      "name": "Recursos do Sistema (CPU e RAM)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{apiKey}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/system/resources",
          "host": ["{{baseUrl}}"],
          "path": ["system", "resources"]
        },
        "description": "Retorna informações de recursos do sistema (memória e CPU)"
      }
    },
