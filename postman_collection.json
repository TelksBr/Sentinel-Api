            "body": {
              "mode": "raw",
              "raw": "[\n  {\n    \"username\": \"usuario1\",\n    \"password\": \"senha123456\",\n    \"limit\": 0,\n    \"validate\": 30,\n    \"is_test\": false,\n    \"time\": 0\n  },\n  {\n    \"username\": \"usuario2\",\n    \"password\": \"outrasenha789\",\n    \"limit\": 0,\n    \"validate\": 60,\n    \"is_test\": false,\n    \"time\": 0\n  }\n]"
