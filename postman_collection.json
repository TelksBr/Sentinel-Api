            ],
            "url": {
              "raw": "{{baseUrl}}/ssh_user/disable/usuario1",
              "host": ["{{baseUrl}}"],
              "path": ["ssh_user", "disable", "usuario1"]
            },
            "description": "Desabilita um usuário SSH (remove data de expiração)"
          }
        },
        {
          "name": "Habilitar Usuário SSH",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{apiKey}}",
                "type": "text"
