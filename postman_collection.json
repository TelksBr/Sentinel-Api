      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{apiKey}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/users/online",
          "host": ["{{baseUrl}}"],
          "path": ["users", "online"]
        },
        "description": "Retorna lista detalhada de usuários SSH, V2Ray e DT-Proto online (do cache)"
      },
